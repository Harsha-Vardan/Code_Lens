# ═══════════════════════════════════════════════════════════
# CodeLens — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ── REQUIRED ──────────────────────────────────────────────

# Anthropic API Key (for Claude answer generation)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OPTIONAL (have defaults) ─────────────────────────────

# Qdrant vector database URL
# Default: http://localhost:6333 (local Docker container)
QDRANT_URL=http://localhost:6333

# Redis URL (used for job queue in production)
# Default: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Backend API URL (used by the Next.js frontend)
# Default: http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
